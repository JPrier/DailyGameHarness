{
  "schemaVersion": "daily-game-content-manifest.v1",
  "gameId": "city-grid",
  "displayName": "City Grid",
  "inputModes": [
    "text"
  ],
  "defaultMaxGuesses": 6,
  "puzzleResolver": {
    "mode": "static-pool",
    "timezone": "America/New_York",
    "startDate": "2026-01-01",
    "poolVersions": [
      {
        "version": "v1",
        "startDate": "2026-01-01",
        "poolSize": 1000,
        "pathPattern": "content/puzzles/v1/puzzle-{index:04}.json",
        "selector": {
          "type": "affine-permutation",
          "a": 137,
          "b": 431
        },
        "cyclePolicy": "repeat"
      }
    ]
  },
  "archive": {
    "mode": "rolling-window",
    "days": 30,
    "includeToday": true,
    "allowFutureDates": false,
    "directAccess": "within-archive-window"
  },
  "extension": {
    "specVersion": "city-grid.spec.v1",
    "candidateSet": "fixture-famous-cities-v1",
    "candidateFile": "content/candidates/fixture-famous-cities-v1.json",
    "sourceManifest": "content/source/osm-source-manifest.json",
    "distanceUnit": "mi",
    "assetKind": "svg"
  }
}
