{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "types": [
      "node",
      "vitest/globals"
    ],
    "allowJs": true,
    "skipLibCheck": true
  },
  "include": [
    "src",
    "tests"
  ]
}