{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "gameId", "puzzleId", "date", "seed", "display", "extension"],
  "properties": {
    "schemaVersion": {"const": "daily-game-puzzle.v1"},
    "gameId": {"type": "string"},
    "puzzleId": {"type": "string"},
    "date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "seed": {"type": "string"},
    "display": {"type": "object", "required": ["title", "initialPrompt"], "properties": {"title": {"type": "string"}, "initialPrompt": {"type": "string"}}, "additionalProperties": true},
    "assets": {"type": "object", "additionalProperties": true},
    "extension": {"type": "object", "additionalProperties": true}
  }
}
