{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "contractVersion", "game", "runtime", "ui", "content", "extension"],
  "properties": {
    "schemaVersion": {"const": "daily-game-package.v1"},
    "contractVersion": {"const": "daily-game-runtime.v1"},
    "game": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug", "displayName"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "slug": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
        "displayName": {"type": "string", "minLength": 1},
        "shortDescription": {"type": "string"},
        "category": {"type": "string"},
        "status": {"type": "string"}
      }
    },
    "runtime": {"type": "object", "additionalProperties": true, "required": ["entry"], "properties": {"entry": {"type": "string", "minLength": 1}}},
    "ui": {"type": "object", "additionalProperties": true, "required": ["entry"], "properties": {"entry": {"type": "string", "minLength": 1}}},
    "content": {"type": "object", "additionalProperties": true, "required": ["manifest", "puzzlesDir"], "properties": {"manifest": {"type": "string"}, "puzzlesDir": {"type": "string"}, "assetsDir": {"type": "string"}, "dateIndex": {"type": "string"}}},
    "staticGeneration": {"type": "object", "required": ["dateDiscovery"], "properties": {"dateDiscovery": {"type": "object", "required": ["mode", "path"], "properties": {"mode": {"const": "date-index"}, "path": {"type": "string"}}}}, "additionalProperties": true},
    "build": {"type": "object", "additionalProperties": true},
    "extension": {"type": "object", "additionalProperties": true}
  }
}
