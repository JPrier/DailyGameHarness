{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "gameId", "inputModes", "puzzleResolver", "archive", "extension"],
  "properties": {
    "schemaVersion": {"const": "daily-game-content-manifest.v1"},
    "gameId": {"type": "string", "minLength": 1},
    "displayName": {"type": "string"},
    "defaultMaxGuesses": {"type": "integer", "minimum": 1},
    "inputModes": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "share": {"type": "object"},
    "puzzleResolver": {"$ref": "puzzle-resolver.schema.json"},
    "archive": {"$ref": "archive-config.schema.json"},
    "assetLoading": {"type": "object"},
    "puzzleSchema": {"type": "object"},
    "extension": {"type": "object", "additionalProperties": true}
  }
}
