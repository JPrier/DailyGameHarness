{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "site", "games", "staticGeneration", "deployment"],
  "properties": {
    "schemaVersion": {"const": "daily-game-harness.v1"},
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "baseUrl", "routePrefix"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "baseUrl": {"type": "string", "format": "uri"},
        "routePrefix": {"type": "string", "pattern": "^$|^/[a-zA-Z0-9/_-]*$"},
        "defaultTimezone": {"type": "string"}
      }
    },
    "games": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source"],
        "properties": {
          "source": {
            "oneOf": [
              {"type": "object", "additionalProperties": false, "required": ["type", "path"], "properties": {"type": {"const": "local"}, "path": {"type": "string", "minLength": 1}}},
              {"type": "object", "additionalProperties": false, "required": ["type", "repo", "ref"], "properties": {"type": {"const": "git"}, "repo": {"type": "string", "minLength": 1}, "ref": {"type": "string", "minLength": 1}}}
            ]
          }
        }
      }
    },
    "staticGeneration": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "outputDir": {"type": "string"},
        "generatedDir": {"type": "string"},
        "externalGamesDir": {"type": "string"},
        "publicGamesDir": {"type": "string"},
        "routeMode": {"const": "single-shell"}
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "target": {"enum": ["github-pages", "s3"]},
        "githubPages": {"type": "object"},
        "bucketEnv": {"type": "string"},
        "regionEnv": {"type": "string"},
        "cloudFrontDistributionIdEnv": {"type": "string"}
      }
    }
  }
}
